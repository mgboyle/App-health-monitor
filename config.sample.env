# Sample Configuration for App Health Monitor

# You can copy this file to `.env` and modify the values as needed

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=production

# Database Configuration
# For SQLite (default):
DATABASE_URL=sqlite:///health_monitor.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/health_monitor
# For MySQL:
# DATABASE_URL=mysql://user:password@localhost/health_monitor

# Health Check Settings
DEFAULT_CHECK_INTERVAL=60  # seconds
DEFAULT_TIMEOUT=30  # seconds
MAX_HEALTH_CHECK_HISTORY=1000  # maximum number of health check records to keep per endpoint

# Application Settings
PORT=5000
HOST=0.0.0.0

# Azure Key Vault Settings (for mTLS certificates in production/AKS)
# Leave empty for local development with file-based certificates
AZURE_KEYVAULT_URL=  # e.g., https://myvault.vault.azure.net/
# Note: Authentication uses DefaultAzureCredential which supports:
# - Managed Identity (in AKS) - preferred for production
# - Azure CLI credentials (az login) - for local development
# - Environment variables (AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_CLIENT_SECRET)

# Example Endpoints Configuration (for reference)
# You can add these through the web UI or API after the application starts

# Example 1: REST API
# Name: Production API
# URL: https://api.example.com/health
# Type: REST
# Check Interval: 60
# Timeout: 30

# Example 2: WCF Service
# Name: Legacy WCF Service
# URL: https://service.example.com/Service.svc
# Type: WCF
# Check Interval: 120
# Timeout: 45

# Example 3: mTLS-protected REST API (using local certificates)
# Name: Secure API
# URL: https://secure-api.example.com/health
# Type: REST
# mTLS Enabled: Yes
# Certificate Source: file
# Certificate Path: /path/to/client-cert.pem
# Key Path: /path/to/client-key.pem

# Example 4: mTLS-protected REST API (using Azure Key Vault)
# Name: Secure API (Production)
# URL: https://secure-api.example.com/health
# Type: REST
# mTLS Enabled: Yes
# Certificate Source: keyvault
# Key Vault Certificate Name: my-client-cert
