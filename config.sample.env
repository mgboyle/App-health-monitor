# Sample Configuration for App Health Monitor

# You can copy this file to `.env` and modify the values as needed

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=production

# Database Configuration
# For SQLite (default):
DATABASE_URL=sqlite:///health_monitor.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/health_monitor
# For MySQL:
# DATABASE_URL=mysql://user:password@localhost/health_monitor

# Health Check Settings
DEFAULT_CHECK_INTERVAL=60  # seconds
DEFAULT_TIMEOUT=30  # seconds
MAX_HEALTH_CHECK_HISTORY=1000  # maximum number of health check records to keep per endpoint

# Application Settings
PORT=5000
HOST=0.0.0.0

# Example Endpoints Configuration (for reference)
# You can add these through the web UI or API after the application starts

# Example 1: REST API
# Name: Production API
# URL: https://api.example.com/health
# Type: REST
# Check Interval: 60
# Timeout: 30

# Example 2: WCF Service
# Name: Legacy WCF Service
# URL: https://service.example.com/Service.svc
# Type: WCF
# Check Interval: 120
# Timeout: 45
